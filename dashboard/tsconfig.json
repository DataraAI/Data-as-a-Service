{
  "compilerOptions": {
    /* Base Options */
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode (Vite standard) */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx", // Or "preserve" if using Vue

    /* Linting / Strictness */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Composite / Build */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    
    /* Interop */
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",           // Your app code
    "vite.config.js",     // Build tool
    "tailwind.config.js", // Style config
    "postcss.config.js"   // CSS tool
  ]
}