# DataraAI Environment Configuration
# Copy this file to .env and update with your values

# ==========================================
# Flask & Backend Configuration
# ==========================================

# Flask environment: development, production
FLASK_ENV=development

# Flask app name
FLASK_APP=src/app.py

# Flask server configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# FiftyOne port
FIFTYONE_PORT=5151

# Secret key for Flask sessions (generate with: python -c 'import secrets; print(secrets.token_hex(32))')
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# ==========================================
# Frontend Configuration
# ==========================================

# API endpoint for frontend
VITE_API_URL=http://localhost:5000

# Frontend port (Vite dev server)
VITE_PORT=5173

# Frontend build mode
VITE_MODE=development

# ==========================================
# Database Configuration
# ==========================================

# MongoDB Connection
# Format: mongodb://[user[:password]@]host:port[/database]
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=datara_db
MONGODB_USER=admin
MONGODB_PASSWORD=your-mongodb-password

# Connection string (alternative to individual settings)
MONGODB_URI=mongodb://admin:your-mongodb-password@localhost:27017/datara_db

# ==========================================
# Azure Configuration
# ==========================================

# Azure Storage Account
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Cosmos DB (optional)
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key

# Azure Blob Storage Container
AZURE_BLOB_CONTAINER=datasets
AZURE_BLOB_CONTAINER_MODELS=models

# Azure Service Principal (for managed identity)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ==========================================
# AWS Configuration
# ==========================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Lambda Configuration
LAMBDA_FUNCTION_NAME=datara-inference
LAMBDA_ROLE_ARN=arn:aws:iam::account-id:role/lambda-role

# ==========================================
# Dataset & Training Configuration
# ==========================================

# FiftyOne Configuration
FIFTYONE_DATABASE_URI=mongodb://admin:password@localhost:27017/fiftyone
FIFTYONE_CONFIG_DIR=~/.fiftyone

# Dataset paths
DATASET_BASE_PATH=/app/dataset
DATASET_TRAIN_PATH="${DATASET_BASE_PATH}/train"
DATASET_TEST_PATH="${DATASET_BASE_PATH}/test"
DATASET_UPLOAD_FOLDER=/app/uploads

# Training configuration
MAX_TRAINING_EPOCHS=100
BATCH_SIZE=32
LEARNING_RATE=0.001
MODEL_SAVE_PATH=/app/models

# ==========================================
# ML Model Configuration
# ==========================================

# Model selection
DEFAULT_MODEL=deeplab
SUPPORTED_MODELS=deeplab,resnet,seam_path,segmentation

# Model checkpoint path
MODEL_CHECKPOINT_PATH=/app/models/checkpoints

# ==========================================
# Logging Configuration
# ==========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=/app/logs/datara.log

# ==========================================
# Security Configuration
# ==========================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost

# API rate limiting (requests per minute)
RATE_LIMIT=100

# Session timeout (minutes)
SESSION_TIMEOUT=1440

# ==========================================
# Robotics Configuration
# ==========================================

# Robotics service port
ROBOTICS_PORT=5002

# Robotics model path
ROBOTICS_MODEL_PATH=/app/robotics/models

# Camera configuration
CAMERA_ID=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# ==========================================
# Docker Configuration
# ==========================================

# Docker image name
DOCKER_IMAGE_NAME=datara-ai

# Docker image tag
DOCKER_IMAGE_TAG=latest

# Docker registry (optional)
DOCKER_REGISTRY=

# ==========================================
# Feature Flags
# ==========================================

# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Enable detailed logging
ENABLE_DEBUG_LOGGING=false

# Enable performance profiling
ENABLE_PROFILING=false

# Enable test mode
TEST_MODE=false



